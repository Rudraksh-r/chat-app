# Server port
PORT=5001

# MongoDB Atlas connection string (include DB name in the URI or let code append it)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net

# CORS allowed origin (frontend URL)
CORS_ORIGIN=http://localhost:5173

# JWT access token signing secret (use a long random string, e.g. openssl rand -base64 64)
ACCESS_TOKEN_SECRET=your_access_token_secret_here

# JWT access token lifetime (e.g. 1d, 15m, 2h)
ACCESS_TOKEN_EXPIRY=1d

# JWT refresh token signing secret (must be different from access token secret)
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# JWT refresh token lifetime
REFRESH_TOKEN_EXPIRY=7d

# Cloudinary credentials (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Node environment (development | production)
NODE_ENV=development

# --- Rate Limiting Thresholds ---
# Auth IP-based limiting (strict)
RATE_LIMIT_AUTH_IP_MAX=20
RATE_LIMIT_AUTH_IP_WINDOW_MS=60000

# Auth account-based limiting (email brute-force protection, failed logins only)
RATE_LIMIT_AUTH_ACCOUNT_MAX=5
RATE_LIMIT_AUTH_ACCOUNT_WINDOW_MS=60000

# Moderate endpoints (search, conversation creation, group management)
RATE_LIMIT_MODERATE_MAX=30
RATE_LIMIT_MODERATE_WINDOW_MS=60000

# Loose endpoints (active messaging, message edit/delete/react)
RATE_LIMIT_LOOSE_MAX=120
RATE_LIMIT_LOOSE_WINDOW_MS=60000

# Socket authentication layer failure limiting
RATE_LIMIT_SOCKET_AUTH_MAX=10
RATE_LIMIT_SOCKET_AUTH_WINDOW_MS=60000
RATE_LIMIT_SOCKET_AUTH_BLOCK_MS=300000

# Typing event limiter
RATE_LIMIT_TYPING_MAX=5
RATE_LIMIT_TYPING_WINDOW_MS=1000

# Reaction event cooldown
RATE_LIMIT_REACTION_WINDOW_MS=500

